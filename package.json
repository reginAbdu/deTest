{
  "name": "debridge",
  "version": "1.0.0",
  "main": "index.js",
  "description": "deBridge Crypto API Tests - TDD Style with Playwright & TypeScript",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist test-results playwright-report .playwright"
  },
  "keywords": [
    "debridge",
    "crypto",
    "api",
    "testing",
    "playwright",
    "typescript",
    "tdd"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "ethers": "^6.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
